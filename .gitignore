!models/.gitkeep

# Experiment tracking (regenerated by running training; local SQLite db, not portable)
experiments/mlruns/
experiments/*.db
experiments/*.db-journal
mlruns/

# Logs
logs/*
!logs/.gitkeep

# Python
__pycache__/
*.py[cod]
*.egg-info/
.eggs/
build/
dist/
.venv/
venv/

# Env
.env

# Editors / OS
.vscode/
.idea/
.DS_Store
Thumbs.db

# Jupyter
.ipynb_checkpoints/

# Pytest / coverage
