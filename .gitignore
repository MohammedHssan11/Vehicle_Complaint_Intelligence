# Data (large NHTSA CSVs + generated splits — not committed)
data/raw/*.csv
data/interim/*
data/processed/*
!data/raw/.gitkeep
!data/interim/.gitkeep
!data/processed/.gitkeep

# Model artifacts
artifacts/*
models/*
